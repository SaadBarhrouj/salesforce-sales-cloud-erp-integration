<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Rule_Action_Sort_Order_Positive</fullName>
    <active>true</active>
    <description>Sort Order, if set, must be a positive number.</description>
    <errorConditionFormula>AND(NOT(ISBLANK(Sort_Order__c)), Sort_Order__c &lt;= 0)</errorConditionFormula>
    <errorDisplayField>Sort_Order__c</errorDisplayField>
    <errorMessage>Sort Order must be a positive number (or leave blank).</errorMessage>
</ValidationRule>
