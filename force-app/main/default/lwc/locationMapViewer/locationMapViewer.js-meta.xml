<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>62.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>Location Map Viewer</masterLabel>
    <description>
        Interactive map displaying the GPS position of a Location record.
    </description>

    <targets>
        <target>lightning__RecordPage</target>
    </targets>

    <targetConfigs>
        <targetConfig targets="lightning__RecordPage">
            <objects>
                <object>Location</object>
            </objects>

            <property name="zoomLevel"
                      type="Integer"
                      default="14"
                      label="Zoom level"
                      description="Initial zoom (1 = world, 20 = building)"
                      min="1" max="20" />

            <property name="mapHeight"
                      type="Integer"
                      default="400"
                      label="Map height (px)"
                      description="Map container height in pixels"
                      min="200" max="800" />

            <property name="hideCoordinates"
                      type="Boolean"
                      default="false"
                      label="Hide coordinates panel"
                      description="Hides the latitude/longitude panel below the map" />

            <property name="hideGoogleMapsLink"
                      type="Boolean"
                      default="false"
                      label="Hide Google Maps link"
                      description="Hides the external link to Google Maps" />
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>